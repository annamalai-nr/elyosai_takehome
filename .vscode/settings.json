{
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor"
    },
    "python.terminal.activateEnvironment": true,
    "python.terminal.activateEnvInCurrentTerminal": true,
    "terminal.integrated.env.osx": {
        "PYTHONPATH": "${workspaceFolder}"
    },
    "git.ignoreLimitWarning": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/backend"
    ],
    "python.analysis.autoSearchPaths": true,

    // ── Disable ALL Python diagnostics (Pylance / Pyright) ──
    "python.linting.enabled": false,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": false,
    "python.linting.mypyEnabled": false,
    "python.linting.banditEnabled": false,
    "python.analysis.typeCheckingMode": "off",
    "python.analysis.ignore": ["**"],
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "none",
        "reportMissingModuleSource": "none",
        "reportGeneralTypeIssues": "none",
        "reportOptionalMemberAccess": "none",
        "reportOptionalSubscript": "none",
        "reportPrivateImportUsage": "none",
        "reportUnusedImport": "none",
        "reportUnusedVariable": "none",
        "reportUnusedExpression": "none",
        "reportUndefinedVariable": "none",
        "reportAttributeAccessIssue": "none"
    },

    // ── Disable Cursor's built-in Pyright (cursorpyright) ──
    "cursorpyright.analysis.autoSearchPaths": true,
    "cursorpyright.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/backend"
    ],
    "cursorpyright.analysis.typeCheckingMode": "off",
    "cursorpyright.analysis.ignore": ["**"],
    "cursorpyright.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "none",
        "reportMissingModuleSource": "none",
        "reportGeneralTypeIssues": "none",
        "reportOptionalMemberAccess": "none",
        "reportOptionalSubscript": "none",
        "reportPrivateImportUsage": "none",
        "reportUnusedImport": "none",
        "reportUnusedVariable": "none",
        "reportUnusedExpression": "none",
        "reportUndefinedVariable": "none",
        "reportAttributeAccessIssue": "none"
    },

    // ── Disable Pylint extension ──
    "pylint.enabled": false,
    "pylint.args": ["--disable=all"],

    // ── Disable Flake8 extension ──
    "flake8.enabled": false,
    "flake8.args": ["--ignore=E,W,F,C,N,B", "--max-line-length=9999"],

    // ── Disable Ruff extension ──
    "ruff.enable": false,

    // ── Disable mypy extension ──
    "mypy-type-checker.enabled": false,
    "mypy.enabled": false,

    // ── Editor ──
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.git": true,
        "**/.DS_Store": true
    },
    "search.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true
    }
}
